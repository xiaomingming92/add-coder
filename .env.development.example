# 复制为 .env.development
# compose 和 Prisma 共用这一个文件

# 数据库凭据
DATABASE_USER=<DATABASE_USER>
DATABASE_PASSWORD=<DATABASE_PASSWORD>
DATABASE_PORT=<DATABASE_PORT>
PROJECT_NAME=<PROJECT_NAME>

# Prisma 连接串（init 自动生成，之后可手动改）
DATABASE_URL="postgresql://<DATABASE_USER>:<DATABASE_PASSWORD>@localhost:<DATABASE_PORT>/<PROJECT_NAME>?schema=public"
