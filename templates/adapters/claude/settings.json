{
    "hooks": {
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/session-start.sh"
                    }
                ]
            }
        ],
        "UserPromptSubmit": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/prompt-submit.sh"
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Write|Edit|Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/pre-tool-use.sh"
                    },
                    {
                        "type": "command",
                        "command": ".claude/hooks/doc-format-guard.sh"
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Write|Edit|Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/post-tool-use.sh"
                    },
                    {
                        "type": "command",
                        "command": ".claude/hooks/doc-format-guard.sh"
                    }
                ]
            }
        ],
        "PostToolUseFailure": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/post-tool-failure.sh"
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/stop-check.sh"
                    }
                ]
            }
        ],
        "SubagentStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/subagent-guard.sh"
                    }
                ]
            }
        ],
        "SubagentStop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/subagent-guard.sh"
                    }
                ]
            }
        ],
        "PreCompact": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/pre-compact.sh"
                    }
                ]
            }
        ],
        "Notification": [
            {
                "matcher": "result",
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/notification.sh"
                    }
                ]
            }
        ],
        "PermissionRequest": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/permission-gate.sh"
                    }
                ]
            }
        ]
    }
}