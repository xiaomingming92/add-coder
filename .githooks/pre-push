#!/usr/bin/env bash
# pre-push hook — 推送前质量门禁
# build + lint 任一不通过即阻断推送
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

echo "==> pnpm build ..."
if ! pnpm build > /dev/null 2>&1; then
  echo "" >&2
  echo "╔══════════════════════════════════════╗" >&2
  echo "║  ❌ build 失败，推送已阻断            ║" >&2
  echo "╚══════════════════════════════════════╝" >&2
  exit 1
fi

echo "==> pnpm lint ..."
if ! pnpm lint --no-warnings > /dev/null 2>&1; then
  echo "" >&2
  echo "╔══════════════════════════════════════╗" >&2
  echo "║  ❌ lint 未通过，推送已阻断           ║" >&2
  echo "╚══════════════════════════════════════╝" >&2
  exit 1
fi

cat <<'NEXT'
✅ build + lint 通过

后续:
  1. npm version patch -m "v%s"
  2. git tag -af "v$(node -p "require('./package.json').version")" -m "Release notes ..."
  3. git push origin main --tags
NEXT
